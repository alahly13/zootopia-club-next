rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // Zootopia Club Next - Server-Authoritative Firestore Rules
    // =========================================================
    //
    // Current architecture:
    // - Browser clients do NOT read or write app documents directly.
    // - All protected reads/writes go through:
    //   - Next.js Route Handlers
    //   - server-side session verification
    //   - Firebase Admin SDK
    //
    // This keeps:
    // - admin separation claims-first
    // - uid/workspace isolation controlled by server
    // - profile completion enforcement controlled by server
    // - assessment / infographic persistence controlled by server
    //
    // If the app later introduces direct browser Firestore access,
    // these rules must be redesigned intentionally to match the
    // real collection model and security boundaries.
    //
    // Named database target expected:
    // - zootopia-club-next-database
    //

    function denyClientAccess() {
      return false;
    }

    // -------------------------
    // User records
    // -------------------------
    match /users/{uid} {
      allow read, write: if denyClientAccess();
    }

    // -------------------------
    // Uploaded / extracted / generated documents
    // -------------------------
    match /documents/{documentId} {
      allow read, write: if denyClientAccess();
    }

    // -------------------------
    // Assessment generations
    // -------------------------
    match /assessmentGenerations/{generationId} {
      allow read, write: if denyClientAccess();
    }

    // -------------------------
    // Infographic generations
    // -------------------------
    match /infographicGenerations/{generationId} {
      allow read, write: if denyClientAccess();
    }

    // -------------------------
    // Admin activity / audit logs
    // -------------------------
    match /adminActivityLogs/{logId} {
      allow read, write: if denyClientAccess();
    }

    // -------------------------
    // Any future collection
    // -------------------------
    match /{document=**} {
      allow read, write: if denyClientAccess();
    }
  }
}